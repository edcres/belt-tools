<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainLayoutActivity" android:background="@color/colorAccent">

    <LinearLayout
            android:layout_width="381dp"
            android:layout_height="803dp"
            android:layout_marginStart="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <TextView
                        android:id="@+id/titleSqrFootIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="15dp"
                        android:text="Get Sqr Ft/In"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/sqrtBox1"
                            android:layout_width="65dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="width"
                            android:inputType="number|numberDecimal" />

                    <EditText
                            android:id="@+id/sqrtBox2"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="length"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/sqrtEqualsButton"
                            android:layout_width="25dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="=" />

                    <TextView
                            android:id="@+id/sqrtBoxResult"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingLeft="10dp"
                            android:text="0"
                            android:textSize="18sp" />
                </LinearLayout>

                <TextView
                        android:id="@+id/textView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:text="Tile Boxes"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="85dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                        <EditText
                                android:id="@+id/homeSqrFt"
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ems="10"
                                android:hint="total sqr ft"
                                android:inputType="number|numberDecimal" />

                        <EditText
                                android:id="@+id/boxSqrFt"
                                android:layout_width="10dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ems="10"
                                android:hint="box sqr ft"
                                android:inputType="number|numberDecimal" />
                    </LinearLayout>

                    <Button
                            android:id="@+id/tileBoxResultsButton"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="boxes" />

                </LinearLayout>

                <TextView
                        android:id="@+id/titleSqrFootToSqrIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="14sp"
                        android:paddingTop="10dp"
                        android:text="Sqr Ft   &lt;--->   Sqr In"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/sqrFootBox"
                            android:layout_width="8dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:baselineAligned="false"
                            android:ems="10"
                            android:hint="sqr ft"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/sqrFootToSqrInButton"
                            android:layout_width="7dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="&lt;-&gt;" />

                    <EditText
                            android:id="@+id/sqrInBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="sqr in"
                            android:inputType="number|numberDecimal" />
                </LinearLayout>

                <TextView
                        android:id="@+id/titleCutBlindWidth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:text="Cut Blind"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/windowWidthBox"
                            android:layout_width="106dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="window width"
                            android:inputType="number|numberDecimal" />

                    <EditText
                            android:id="@+id/blindWidthBox"
                            android:layout_width="99dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="blind width"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/blindWidthEqualsButton"
                            android:layout_width="63dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="="
                            android:textSize="14sp" />

                    <TextView
                            android:id="@+id/blindWidthResult"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingLeft="10dp"
                            android:text="0"
                            android:textSize="18sp" />
                </LinearLayout>

                <TextView
                        android:id="@+id/titleDecimaltoFraction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Decimal to Fraction"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/decimalBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="decimal"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/decimalToFractionButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-&gt;" />

                    <EditText
                            android:id="@+id/fractionBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="fraction"
                            android:inputType="number|numberDecimal" />
                </LinearLayout>

                <TextView
                        android:id="@+id/titleLinealFtToSqrYard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lineal Ft to Sqr Yard"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/linealFtBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="lineal feet"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/linealFtToSqrYardButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-&gt;" />

                    <EditText
                            android:id="@+id/sqrYardBox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="sqr yard"
                            android:inputType="number|numberDecimal" />
                </LinearLayout>

                <TextView
                        android:id="@+id/titleGetTax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="14sp"
                        android:paddingTop="10dp"
                        android:text="7% Tax"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <EditText
                            android:id="@+id/amountBox"
                            android:layout_width="6dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ems="10"
                            android:hint="amount"
                            android:inputType="number|numberDecimal" />

                    <Button
                            android:id="@+id/plusTaxButton"
                            android:layout_width="27dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="plus tax"
                            android:textAllCaps="true" />

                    <TextView
                            android:id="@+id/afterTaxBox"
                            android:layout_width="19dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingLeft="10dp"
                            android:text="0"
                            android:textSize="18sp" />
                </LinearLayout>

                <TextView
                        android:id="@+id/textView2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:text="Lineal Backsplash"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">

                            <EditText
                                    android:id="@+id/bakShWidthBox"
                                    android:layout_width="113dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:ems="10"
                                    android:hint="12 in. width"
                                    android:inputType="number|numberDecimal" />

                            <EditText
                                    android:id="@+id/linealSpaceBox"
                                    android:layout_width="121dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:ems="10"
                                    android:hint="lineal space (in)"
                                    android:inputType="number|numberDecimal" />

                            <ToggleButton
                                    android:id="@+id/bakShToggleButton"
                                    android:layout_width="15dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:lineSpacingExtra="10sp"
                                    android:text="ToggleButton"
                                    android:textAllCaps="false"
                                    android:textOff="ft."
                                    android:textOn="in."
                                    android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal">

                            <EditText
                                    android:id="@+id/cutOutsBox"
                                    android:layout_width="2dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:ems="10"
                                    android:hint="cut outs"
                                    android:inputType="number|numberDecimal" />

                            <Button
                                    android:id="@+id/bakShEqualsButton"
                                    android:layout_width="25dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="=" />

                            <TextView
                                    android:id="@+id/bakShResultsBox"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:paddingLeft="10dp"
                                    android:text="0"
                                    android:textSize="18sp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <Button
                            android:id="@+id/moreOptionsButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="More..." />

                    <Button
                            android:id="@+id/resetAllButton"
                            android:layout_width="187dp"
                            android:layout_height="wrap_content"
                            android:text="Reset All" />

                </LinearLayout>

                <TextView
                        android:id="@+id/textView5"
                        android:layout_width="wrap_content"
                        android:layout_height="500dp"
                        android:layout_weight="1"
                        android:textSize="120sp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</android.support.constraint.ConstraintLayout>
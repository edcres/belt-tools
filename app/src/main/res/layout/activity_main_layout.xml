<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainLayoutActivity" android:background="@color/colorAccent">

    <LinearLayout
            android:layout_width="389dp"
            android:layout_height="682dp"
            android:layout_marginStart="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="95dp"
            android:layout_marginEnd="8dp"
            android:layout_marginRight="8dp"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <TextView
                android:id="@+id/titleSqrFootIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Sqr Foot or Inch"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/sqrtBox1"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="width"
                    android:inputType="number" />

            <EditText
                    android:id="@+id/sqrtBox2"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="length"
                    android:inputType="number" />

            <Button
                    android:id="@+id/sqrtEqualsButton"
                    android:layout_width="25dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="=" />

            <TextView
                    android:id="@+id/sqrtBoxResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingLeft="10dp"
                    android:text="0"
                    android:textSize="18sp" />
        </LinearLayout>

        <TextView
                android:id="@+id/titleSqrFootToSqrIn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="14sp"
                android:text="Sqr Foot to Sqr Inch"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/sqrFootBox"
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:baselineAligned="false"
                    android:ems="10"
                    android:hint="sqr ft"
                    android:inputType="number" />

            <Button
                    android:id="@+id/sqrFootToSqrInButton"
                    android:layout_width="7dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="&lt;-&gt;" />

            <EditText
                    android:id="@+id/sqrInBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="sqr in"
                    android:inputType="number" />
        </LinearLayout>

        <TextView
                android:id="@+id/titleGetTax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="14sp"
                android:text="Get + 7% Tax"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/amountBox"
                    android:layout_width="6dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="amount"
                    android:inputType="number" />

            <Button
                    android:id="@+id/plusTaxButton"
                    android:layout_width="27dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="plus tax"
                    android:textAllCaps="true" />

            <TextView
                    android:id="@+id/afterTaxBox"
                    android:layout_width="19dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingLeft="10dp"
                    android:text="0"
                    android:textSize="18sp" />
        </LinearLayout>

        <TextView
                android:id="@+id/titleCutBlindWidth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Blind Width"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/windowWidthBox"
                    android:layout_width="106dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="window width"
                    android:inputType="number" />

            <EditText
                    android:id="@+id/blindWidthBox"
                    android:layout_width="99dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="blind width"
                    android:inputType="number" />

            <Button
                    android:id="@+id/blindWidthEqualsButton"
                    android:layout_width="63dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="="
                    android:textSize="14sp" />

            <TextView
                    android:id="@+id/blindWidthResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingLeft="10dp"
                    android:text="0"
                    android:textSize="18sp" />
        </LinearLayout>

        <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tile Boxes"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/homeSqrFt"
                    android:layout_width="10dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="total sqr ft"
                    android:inputType="numberSigned" />

            <EditText
                    android:id="@+id/boxSqrFt"
                    android:layout_width="10dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="box sqr ft"
                    android:inputType="numberSigned" />

            <Button
                    android:id="@+id/resultsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="boxes" />
        </LinearLayout>

        <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lineal Backsplash"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="43dp"
                android:orientation="horizontal">

            <EditText
                    android:id="@+id/linealSpaceBox"
                    android:layout_width="11dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="lineal space"
                    android:inputType="textPersonName" />

            <EditText
                    android:id="@+id/backsplashWidthBox"
                    android:layout_width="21dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="width"
                    android:inputType="textPersonName" />

            <EditText
                    android:id="@+id/cutOutsBox"
                    android:layout_width="2dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ems="10"
                    android:hint="cut outs"
                    android:inputType="textPersonName" />

            <Button
                    android:id="@+id/linealBacksplashEqualsButton"
                    android:layout_width="25dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="=" />

            <TextView
                    android:id="@+id/linealBacksplashResultsBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:layout_weight="1"
                    android:text="0" />
        </LinearLayout>

        <TextView
                android:id="@+id/textView22"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To Be Continued... (one more)"
                android:textSize="24sp"
                android:textStyle="bold" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/button2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="More..." />

            <Button
                    android:id="@+id/button"
                    android:layout_width="187dp"
                    android:layout_height="wrap_content"
                    android:text="Reset All" />
        </LinearLayout>

    </LinearLayout>
</android.support.constraint.ConstraintLayout>
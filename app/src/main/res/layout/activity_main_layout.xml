<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainLayoutActivity" android:background="@color/colorAccent">

    <LinearLayout
            android:orientation="vertical"
            android:layout_width="376dp"
            android:layout_height="495dp" app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp" android:layout_marginRight="8dp"
            android:layout_marginTop="8dp" app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" android:layout_marginLeft="8dp"
            android:layout_marginStart="8dp">
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/titleSqrFootIn" android:textStyle="bold"
                android:textSize="24sp" android:text="Get Sqr Foot or Inch"/>
        <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <EditText
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/sqrtBox1" android:layout_weight="1" android:hint="num 1"/>
            <EditText
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/sqrtBox2" android:layout_weight="1" android:hint="num 2"/>
            <Button
                    android:text="="
                    android:layout_width="25dp"
                    android:layout_height="36dp" android:id="@+id/sqrtEqualsButton" android:layout_weight="1"/>
            <TextView
                    android:text="0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/sqrtBoxResult" android:layout_weight="1"
                    android:textSize="18sp"/>
        </LinearLayout>
        <TextView
                android:text="Sqr Foot to Sqr Inch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/titleSqrFootToSqrIn" android:textStyle="bold"
                android:lineSpacingExtra="14sp" android:textSize="24sp"/>
        <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <EditText
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/sqrFootBox" android:layout_weight="1" android:hint="sqr ft"
                    android:baselineAligned="false"/>
            <Button
                    android:text="&lt;-&gt;"
                    android:layout_width="7dp"
                    android:layout_height="36dp" android:id="@+id/sqrFootToSqrInButton" android:layout_weight="1"/>
            <EditText
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/sqrInBox" android:layout_weight="1" android:hint="sqr in"
            />
        </LinearLayout>
        <TextView
                android:text="Get + 7% Tax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/titleGetTax" android:textStyle="bold"
                android:lineSpacingExtra="14sp" android:textSize="24sp"/>
        <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <EditText
                    android:layout_width="6dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/amountBox" android:layout_weight="1" android:hint="amount"/>
            <Button
                    android:text="plus tax"
                    android:layout_width="27dp"
                    android:layout_height="38dp" android:id="@+id/plusTaxButton" android:layout_weight="1"
                    android:textAllCaps="true"/>
            <TextView
                    android:text="0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/afterTaxBox" android:layout_weight="1"
                    android:textSize="18sp"/>
        </LinearLayout>
        <TextView
                android:text="Blind Width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/titleCutBlindWidth" android:textSize="24sp"
                android:textStyle="bold"/>
        <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <EditText
                    android:layout_width="106dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/windowWidthBox" android:layout_weight="1" android:hint="Window Width"/>
            <EditText
                    android:layout_width="99dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:ems="10"
                    android:id="@+id/blindWidthBox" android:layout_weight="1" android:hint="Blind Width"/>
            <Button
                    android:text="="
                    android:layout_width="63dp"
                    android:layout_height="match_parent" android:id="@+id/blindWidthEqualsButton"
                    android:layout_weight="1" android:textSize="14sp"/>
            <TextView
                    android:text="0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/blindWidthResult" android:layout_weight="1"
                    android:textSize="18sp"/>
        </LinearLayout>
        <TextView
                android:text="To Be Continued..."
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/textView22" android:textSize="24sp"
                android:textStyle="bold"/>
        <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            <Button
                    android:text="More..."
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:id="@+id/button2" android:layout_weight="1"/>
            <Button
                    android:text="Reset All"
                    android:layout_width="187dp"
                    android:layout_height="wrap_content" android:id="@+id/button"
            />
        </LinearLayout>
    </LinearLayout>
</android.support.constraint.ConstraintLayout>
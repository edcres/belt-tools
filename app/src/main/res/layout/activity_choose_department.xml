<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F7AB89"
        tools:context=".choosedepartment.ChooseDepartmentActivity">

    <ScrollView
            android:layout_width="377dp"
            android:layout_height="791dp"
            android:layout_marginStart="8dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginRight="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

            <Button
                    android:id="@+id/proDeskChooseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pro Desk" />

            <Button
                    android:id="@+id/flooringChooseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Flooring" />

            <Button
                    android:id="@+id/customerServiceChooseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Customer Service" />

            <Button
                    android:id="@+id/appliancesChooseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appliances" />

            <Button
                    android:id="@+id/millworkChooseButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Millwork" />
        </LinearLayout>
    </ScrollView>

</android.support.constraint.ConstraintLayout>